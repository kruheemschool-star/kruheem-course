rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'kruheemschool@gmail.com'
      ];
    }

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user owns this document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Coupon helpers
    function isValidReviewRewardCouponCreate() {
      return isAuth()
        && request.resource.data.source == "review_reward"
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isUsed == false
        // Prevent injecting a percentage discount into "review_reward" coupons.
        // IMPORTANT: use get(field, default). Accessing a field that is ABSENT
        // from the document raises an error and denies the whole write. The
        // client never sends discountPercent, so the bare `== null` check below
        // silently broke ALL review-coupon creation. get() treats absent as null
        // while still rejecting any explicitly-set percentage.
        && request.resource.data.get('discountPercent', null) == null
        && request.resource.data.discountAmount == 100
        // REVIEW-XXXXXX (6 chars A-Z/0-9)
        && request.resource.data.code.matches('^REVIEW-[A-Z0-9]{6}$');
    }

    function isValidCouponRedeemUpdate() {
      // Non-admin can only "redeem" a coupon: flip isUsed false -> true (and optionally write usedAt/usedForCourseId)
      return isAuth()
        && resource.data.isUsed == false
        && request.resource.data.isUsed == true
        // If coupon is bound to a user (review reward), only that user can redeem it.
        && (resource.data.userId == null || resource.data.userId == request.auth.uid)
        // Do not allow client to mutate discount/source/ownership/etc.
        && request.resource.data.code == resource.data.code
        && request.resource.data.source == resource.data.source
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.discountAmount == resource.data.discountAmount
        // get(field, default): coupons created before discountPercent existed
        // (every review reward + admin promo) don't carry this key. Comparing a
        // missing key directly errors and denies the redeem. Treat absent as null
        // on both sides so existing coupons can still be marked as used.
        && request.resource.data.get('discountPercent', null) == resource.data.get('discountPercent', null)
        && request.resource.data.createdAt == resource.data.createdAt
        // Only allow these fields to change via client redeem.
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "isUsed",
          "usedAt",
          "usedForCourseId"
        ]);
    }

    // === Users ===
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // User sub-collections (progress, activity, course_states)
      match /{subcollection}/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // === Courses (public read, admin write) ===
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      // Lessons subcollection - public read (for free preview / lesson list)
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Other course sub-collections require auth
      match /{subcollection}/{docId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
    }

    // === Exam Papers (downloadable PDF products) ===
    // Public read = card metadata (title, price, cover, preview) for the shop.
    // The private master PDF lives in Storage and is NOT reachable from here —
    // it is only served as a short-lived signed URL by /api/download-pdf after
    // that route verifies an approved enrollment. Admin-only write.
    match /examPapers/{paperId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Enrollments ===
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      // Create: own doc, must start pending, and the price fields must be
      // numerically sane and self-consistent (finalPrice = price - discount,
      // clamped at 0 exactly like both payment forms compute it). This stops
      // hand-crafted enrollments with negative/absurd numbers while accepting
      // every value the real forms can produce. (The slip review remains the
      // human check that the transferred amount matches.)
      allow create: if isAdmin() || (
        isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.discountAmount is number
        && request.resource.data.discountAmount >= 0
        && request.resource.data.finalPrice is number
        && (
          request.resource.data.finalPrice == request.resource.data.price - request.resource.data.discountAmount
          || (request.resource.data.finalPrice == 0
              && request.resource.data.discountAmount >= request.resource.data.price)
        )
      );
      // Update: admin manages status/expiry; the OWNER may fix their own
      // still-pending submission (the /payment/edit page: re-upload slip,
      // correct name/phone/LINE) but can never touch status, price fields,
      // courseId, or anything else.
      allow update: if isAdmin() || (
        isAuth()
        && resource.data.userId == request.auth.uid
        && resource.data.status == "pending"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "userName", "userTel", "lineId", "slipUrl", "lastUpdated"
        ])
      );
      allow delete: if isAdmin();
    }

    // === Reviews (public read, authenticated create, admin manage) ===
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // === Coupons ===
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isValidReviewRewardCouponCreate();
      allow update: if isAdmin() || isValidCouponRedeemUpdate();
      allow delete: if isAdmin();
    }

    // === Posts / Blog (public read, admin write) ===
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Post Comments (public read, authenticated write) ===
    match /postComments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // === Post Ratings (public read, authenticated write) ===
    match /postRatings/{ratingId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // === Comments ===
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // === Summaries (public read, admin write) ===
    match /summaries/{summaryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Exams (public read, admin write) ===
    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Exam Categories (public read, admin write) ===
    match /examCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Course Categories (public read, admin write) ===
    // Used by /admin/courses page for grouping courses into categories.
    // Public read because the course list / catalog shows category names.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Avatars (public read, admin write) ===
    // Admin-managed avatar library. Students read this collection to
    // populate the avatar picker on /profile. Only admins can upload,
    // delete, or reorder.
    match /avatars/{avatarId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Avatar Categories (public read, admin write) ===
    // Admin-managed category metadata for avatar tabs.
    match /avatarCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Homepage promotion (public read so the homepage can show it; admin write) ===
    match /settings/homepage_promotion {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Settings (admin only) ===
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // === Polls (public read, admin manage, authenticated vote) ===
    // Vote / update requires sign-in so anonymous traffic can't ballot-stuff.
    // If polls are reintroduced, prefer a per-user vote sub-doc instead of
    // letting clients mutate the poll document directly.
    match /polls/{pollId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // === Banners (public read, admin write) ===
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Support Tickets ===
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === Notifications ===
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // === Visitors (analytics) ===
    // Anonymous visitors must be able to write (they are not signed in), so we
    // cannot require auth here. Instead we bound the payload so nobody can stuff
    // a giant junk document, and keep reads admin-only. A real presence doc has
    // ~5 fields; 30 is a generous ceiling.
    match /visitors/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.size() < 30;
      allow delete: if isAdmin();
    }

    match /anonymous_visitors/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.size() < 30;
      allow delete: if true; // presence cleanup on unmount / tab close
    }

    // === Stats (analytics counters) ===
    // Written via increment() by anonymous visitors, so writes stay open — but
    // ONLY to the three known counter documents, so attackers cannot create
    // arbitrary `stats/*` junk docs. Reads are admin-only (no public page reads
    // these raw counters; public-facing numbers live in /public_stats).
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if statId in ['daily_visits', 'page_views', 'promo_homepage'];
    }

    // === Public Stats (Aggregated metrics visible to everyone) ===
    match /public_stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Chats / Messages ===
    // Admin-only: the student-facing ChatWidget is disabled (commented out in
    // app/layout.tsx), so the only legitimate writer is the admin console
    // (/admin/chat and the "ส่งข้อความ" action on /admin/students). The old
    // isAuth() rule let ANY signed-in user read and rewrite EVERY chat room.
    // If the student widget is ever re-enabled, relax this to a participant
    // check (e.g. chatId == request.auth.uid), not back to isAuth().
    match /chats/{chatId} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }
  }
}
