rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email in [
        'kruheemschool@gmail.com'
      ];
    }

    // Allow authenticated users to upload slips
    //
    // Note: our app uploads slips as `slips/${uid}_${timestamp}` (single path segment),
    // so we match a single filename here to keep the rule type-safe.
    match /slips/{fileName} {
      // Slips contain sensitive payment info: only the owner (based on filename prefix)
      // and admins can read them.
      allow read: if isAdmin()
                 || (isAuth() && fileName.matches('^' + request.auth.uid + '_.*'));
      allow write: if isAuth()
                   && fileName.matches('^' + request.auth.uid + '_.*')
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Disallow nested slip paths (defense-in-depth).
    match /slips/{allPaths=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to upload summary images/covers
    match /summaries/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Admin-curated avatar library (public read, admin-only write).
    // Uploaded via /admin/avatars. Must be listed BEFORE the catch-all rule.
    match /static/avatars/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    // Default: allow read for all other paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
